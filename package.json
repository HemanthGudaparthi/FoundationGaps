{
  "name": "contextlens",
  "version": "0.1.0-beta.0",
  "description": "Learning companion — annotate videos with keyword detection, sticky notes, and understanding gap tracking",
  "author": "Hemanth Gudaparthi",
  "license": "UNLICENSED",
  "private": true,
  "workspaces": [
    "packages/main",
    "packages/renderer",
    "packages/shared",
    "packages/keyword-engine"
  ],
  "scripts": {
    "dev":           "concurrently \"npm run dev:main\" \"npm run dev:renderer\"",
    "dev:main":      "npm run build:main -- --watch",
    "dev:renderer":  "vite --config packages/renderer/vite.config.ts",
    "build":         "npm run build:shared && npm run build:renderer && npm run build:main",
    "build:shared":  "tsc -p packages/shared/tsconfig.json",
    "build:renderer":"vite build --config packages/renderer/vite.config.ts",
    "build:main":    "esbuild packages/main/src/index.ts --bundle --platform=node --external:electron --outfile=dist/main.js",
    "lint":          "eslint packages/*/src --ext .ts,.tsx",
    "type-check":    "tsc --noEmit -p tsconfig.json",
    "test:unit":     "vitest run packages/*/src/**/*.test.ts packages/*/src/**/*.test.tsx",
    "test:e2e":      "playwright test --config tests/e2e/playwright.config.ts",
    "test:smoke":    "node tests/smoke/smoke.mjs",
    "test:perf":     "node tests/perf/bench.mjs",
    "coverage:check":"vitest run --coverage --reporter=json && node scripts/check-coverage.mjs",
    "package:mac":   "electron-builder --mac",
    "package:win":   "electron-builder --win",
    "package:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.0.0",
    "concurrently": "^9.0.0",
    "esbuild": "^0.24.0",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^2.0.0"
  }
}
