{
  "name": "foundationgaps",
  "version": "0.1.0-beta.0",
  "description": "FoundationGaps — surface the gaps in your foundation and close them, one concept at a time",
  "author": "Hemanth Gudaparthi",
  "license": "MIT",
  "workspaces": [
    "packages/renderer",
    "packages/shared",
    "packages/keyword-engine"
  ],
  "scripts": {
    "dev":            "vite --config packages/renderer/vite.config.ts",
    "build":          "tsc -p packages/renderer/tsconfig.json && vite build --config packages/renderer/vite.config.ts",
    "preview":        "vite preview --config packages/renderer/vite.config.ts",
    "lint":           "eslint packages/*/src --ext .ts,.tsx",
    "type-check":     "tsc --noEmit -p tsconfig.json",
    "test":           "vitest run",
    "test:e2e":       "playwright test --config tests/e2e/playwright.config.ts",

    "cap:sync":       "npx cap sync",
    "cap:ios":        "npx cap run ios",
    "cap:ios:open":   "npx cap open ios",
    "cap:mac":        "npx cap run @capacitor-community/electron",

    "electron:dev":   "concurrently \"npm run build\" \"wait-on dist/index.html && electron packages/electron/main.js\"",
    "electron:build": "npm run build && electron-builder --config electron-builder.json"
  },
  "dependencies": {
    "@capacitor/app":          "^6.0.0",
    "@capacitor/core":         "^6.0.0",
    "@capacitor/filesystem":   "^6.0.0",
    "@capacitor/haptics":      "^6.0.0",
    "@capacitor/keyboard":     "^6.0.0",
    "@capacitor/preferences":  "^6.0.0",
    "@capacitor/status-bar":   "^6.0.0",
    "@capacitor-community/sqlite": "^6.0.0",
    "react":                   "^18.3.0",
    "react-dom":               "^18.3.0",
    "react-markdown":          "^9.0.0",
    "compromise":              "^14.14.0"
  },
  "devDependencies": {
    "@capacitor/cli":          "^6.0.0",
    "@capacitor/ios":          "^6.0.0",
    "@playwright/test":        "^1.48.0",
    "@types/react":            "^18.3.0",
    "@types/react-dom":        "^18.3.0",
    "@vitejs/plugin-react":    "^4.3.0",
    "@vitest/coverage-v8":     "^2.0.0",
    "concurrently":            "^9.0.0",
    "electron":                "^32.0.0",
    "electron-builder":        "^25.0.0",
    "typescript":              "^5.6.0",
    "vite":                    "^6.0.0",
    "vitest":                  "^2.0.0",
    "wait-on":                 "^8.0.0"
  }
}
